<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Equitide - Real Estate Investment Platform</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Libre+Baskerville:wght@400;700&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .fade-in { animation: fadeIn 0.6s ease-out; }
        .serif { font-family: 'Libre Baskerville', serif; }
        body { font-family: 'Inter', sans-serif; }

        .modal-overlay {
            display: none; position: fixed; inset: 0; z-index: 200;
            background: rgba(0,0,0,0.6); backdrop-filter: blur(4px);
            align-items: center; justify-content: center;
        }
        .modal-overlay.open { display: flex; }
        .chat-modal {
            background: #0a0814;
            border: 1px solid rgba(130,100,255,0.25);
            border-radius: 24px; padding: 32px;
            width: 90%; max-width: 520px;
            position: relative;
        }
        .modal-close {
            position: absolute; top: 14px; right: 18px;
            background: none; border: none;
            color: rgba(255,255,255,0.3); font-size: 20px; cursor: pointer;
        }
        .modal-close:hover { color: #fff; }
        .chat-header {
            display: flex; align-items: center; gap: 14px;
            margin-bottom: 20px; padding-bottom: 16px;
            border-bottom: 1px solid rgba(255,255,255,0.08);
        }
        .chat-header-text h3 {
            font-family: 'Libre Baskerville', serif;
            font-size: 17px; color: #fff; margin-bottom: 2px;
        }
        .chat-header-text p { font-size: 12px; color: rgba(255,255,255,0.35); }
        #modal-chat {
            height: 260px; overflow-y: auto;
            display: flex; flex-direction: column; gap: 10px;
            margin-bottom: 14px; scrollbar-width: none;
        }
        #modal-chat::-webkit-scrollbar { display: none; }
        .mc-user {
            align-self: flex-end;
            background: rgba(130,100,255,0.2);
            border: 1px solid rgba(130,100,255,0.3);
            border-radius: 16px 16px 4px 16px;
            padding: 10px 14px; font-size: 13px; color: #fff;
            max-width: 80%; line-height: 1.5;
        }
        .mc-bot {
            align-self: flex-start;
            background: rgba(255,255,255,0.05);
            border: 1px solid rgba(255,255,255,0.08);
            border-radius: 16px 16px 16px 4px;
            padding: 10px 14px; font-size: 13px;
            color: rgba(255,255,255,0.85);
            max-width: 80%; line-height: 1.6;
        }
        .mc-typing { display: flex; gap: 4px; padding: 12px 14px; }
        .mc-typing span {
            width: 5px; height: 5px;
            background: rgba(255,255,255,0.3); border-radius: 50%;
            animation: bounce 1.2s infinite;
        }
        .mc-typing span:nth-child(2) { animation-delay: 0.2s; }
        .mc-typing span:nth-child(3) { animation-delay: 0.4s; }
        @keyframes bounce {
            0%,60%,100% { transform: translateY(0); }
            30% { transform: translateY(-5px); }
        }
        .modal-input-row { display: flex; gap: 10px; }
        .modal-input {
            flex: 1; background: rgba(255,255,255,0.06);
            border: 1px solid rgba(255,255,255,0.12);
            border-radius: 30px; padding: 12px 18px;
            color: #fff; font-family: 'Inter', sans-serif;
            font-size: 13px; outline: none;
        }
        .modal-input:focus { border-color: rgba(130,100,255,0.5); }
        .modal-input::placeholder { color: rgba(255,255,255,0.2); }
        .modal-send {
            background: rgba(130,100,255,0.25);
            border: 1px solid rgba(130,100,255,0.45);
            border-radius: 30px; padding: 12px 20px;
            color: #c4b0f0; cursor: pointer; font-size: 12px;
            font-family: 'Inter', sans-serif; transition: all 0.3s;
        }
        .modal-send:hover { background: rgba(130,100,255,0.4); }
        .modal-full-link {
            text-align: center; margin-top: 14px;
            font-size: 12px; color: rgba(255,255,255,0.25);
        }
        .modal-full-link a { color: rgba(201,169,97,0.7); text-decoration: none; }
        .modal-full-link a:hover { color: #C9A961; }

        .meridian-card {
            background: #07050f;
            border: 1px solid rgba(130,100,255,0.2);
            border-radius: 20px; padding: 28px;
            display: flex; flex-direction: column;
            align-items: center; gap: 14px;
            text-align: center;
        }
        .meridian-card-label {
            font-family: 'Libre Baskerville', serif;
            font-size: 10px; letter-spacing: 5px;
            text-transform: uppercase; color: rgba(255,255,255,0.3);
        }
        .meridian-card p { font-size: 13px; color: rgba(255,255,255,0.5); line-height: 1.6; }
        .meridian-card-btn {
            background: rgba(130,100,255,0.15);
            border: 1px solid rgba(130,100,255,0.35);
            border-radius: 30px; padding: 10px 22px;
            color: #c4b0f0; font-size: 12px; cursor: pointer;
            font-family: 'Inter', sans-serif; transition: all 0.3s;
        }
        .meridian-card-btn:hover {
            background: rgba(130,100,255,0.3);
            border-color: rgba(130,100,255,0.6);
        }

        /* Stack diagram */
        .stack-layer {
            border-left: 3px solid #C9A961;
            padding: 20px 24px;
            margin-bottom: 4px;
            background: white;
            border-radius: 0 8px 8px 0;
            transition: all 0.3s;
        }
        .stack-layer:hover { background: #faf7f2; }
        .stack-connector {
            width: 3px; height: 16px;
            background: #C9A961; margin-left: 0;
        }
    </style>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        'brand-tan': '#C9A961',
                        'brand-brown': '#8B6F47',
                    }
                }
            }
        }
    </script>
</head>
