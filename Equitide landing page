</nav>

<!-- Hero -->
<section class="pt-32 pb-24 px-6 bg-gradient-to-b from-white to-stone-50">
    <div class="max-w-7xl mx-auto">
        <div class="grid lg:grid-cols-3 gap-16 items-center">
            <div class="lg:col-span-2 space-y-8 fade-in">
                <h1 class="text-6xl lg:text-7xl font-bold leading-tight text-slate-900 serif">
                    We don't just invest in real estate.<br/>
                    <span class="text-brand-brown">We build it.</span>
                </h1>
                <p class="text-xl text-slate-600 leading-relaxed max-w-xl">
                    From land acquisition and entitlements through offsite and onsite construction, our vertically integrated model eliminates the conflicts that make traditional development so expensive. Lower costs mean better returns for investors and more affordable rents for tenants.
                </p>
                <div>
                    <p class="text-sm text-slate-500 mb-4 font-medium uppercase tracking-wide">Opening soon to accredited investors</p>
                    <button onclick="document.getElementById('waitlist-section').scrollIntoView({behavior:'smooth'})"
