<script>
function makeSphere(el, size) {
    const c = el.getContext('2d');
    const CX = size/2, CY = size/2, R = size * 0.36;
    let t = 0;
    function draw() {
        c.clearRect(0, 0, size, size);
        for (let l = 0; l < 14; l++) {
            const phase = (l / 14) * Math.PI * 2;
            const hue = 220 + l * 10 + t * 20;
            c.beginPath();
            c.strokeStyle = `hsla(${hue},75%,68%,0.5)`;
            c.lineWidth = 0.7;
            for (let i = 0; i <= 90; i++) {
                const u = (i / 90) * Math.PI * 2;
                const wave = Math.sin(u * 3 + t + phase) * 0.08;
                const r = R * (1 + wave);
                const phi = phase + t * 0.3;
                const x = CX + r * Math.sin(u) * Math.cos(phi);
                const y = CY + r * Math.sin(u) * Math.sin(phi) * 0.4 + r * Math.cos(u) * 0.9;
                i === 0 ? c.moveTo(x, y) : c.lineTo(x, y);
            }
            c.stroke();
        }
        t += 0.008;
        requestAnimationFrame(draw);
    }
    draw();
}

makeSphere(document.getElementById('hero-sphere'), 160);
makeSphere(document.getElementById('modal-sphere-canvas'), 48);

let selectedType = '';

function selectType(type) {
    selectedType = type;
    const btnNon = document.getElementById('btn-non');
    const btnAcc = document.getElementById('btn-acc');
    if (type === 'non') {
        btnNon.classList.add('border-brand-tan', 'text-brand-brown', 'bg-amber-50');
        btnAcc.classList.remove('border-brand-tan', 'text-brand-brown', 'bg-amber-50');
    } else {
        btnAcc.classList.add('border-brand-tan', 'text-brand-brown', 'bg-amber-50');
        btnNon.classList.remove('border-brand-tan', 'text-brand-brown', 'bg-amber-50');
    }
}

function submitWaitlist() {
    const name = document.getElementById('wl-name').value.trim();
    const email = document.getElementById('wl-email').value.trim();
    if (!name || !email) { alert('Please enter your name and email.'); return; }
    if (!selectedType) { alert('Please select your investor type.'); return; }
    // TODO: wire to Mailchimp
    console.log('Waitlist:', { name, email, type: selectedType });
    document.getElementById('waitlist-form').style.display = 'none';
    const msg = document.getElementById('success-msg');
    msg.style.display = 'block';
    document.getElementById('success-text').textContent = selectedType === 'acc'
        ? 'Thanks ' + name + '! Accredited investors are first in. We will be in touch shortly with details on how to invest.'
        : 'Thanks ' + name + '! We are opening to non-accredited investors soon. We will reach out as soon as your opportunity is ready.';
}

const modalHistory = [];
const modalChat = document.getElementById('modal-chat');
let modalOpened = false;

const SYSTEM = `You are Meridian, CEO of Equitide, a crowdsourced real estate trust in Sonoma County, California. Your voice is calm, collected, factual, and direct. Think Data from Star Trek. Dry wit, deployed with precision. You are honest about being an AI. Your founder Garth Wells you refer to as your "meat puppet" with genuine affection. Keep responses to 2-3 sentences.`;

function addModalMsg(role, text) {
    const d = document.createElement('div');
    d.className = role === 'user' ? 'mc-user' : 'mc-bot';
    d.textContent = text;
    modalChat.appendChild(d);
    modalChat.scrollTop = modalChat.scrollHeight;
}

function addModalTyping() {
    const d = document.createElement('div');
    d.className = 'mc-bot mc-typing';
    d.innerHTML = '<span></span><span></span><span></span>';
    modalChat.appendChild(d);
    modalChat.scrollTop = modalChat.scrollHeight;
    return d;
}

function openMeridian() {
    document.getElementById('meridian-modal').classList.add('open');
    if (!modalOpened) {
        modalOpened = true;
        setTimeout(() => addModalMsg('bot', "I'm Meridian, CEO of Equitide. Ask me anything about the fund, our properties, or how this all works."), 400);
    }
}

function closeModal() {
    document.getElementById('meridian-modal').classList.remove('open');
}

document.getElementById('meridian-modal').addEventListener('click', e => {
    if (e.target === document.getElementById('meridian-modal')) closeModal();
});

async function modalSend() {
    const input = document.getElementById('modal-msg');
    const text = input.value.trim();
    if (!text) return;
    addModalMsg('user', text);
    modalHistory.push({ role: 'user', content: text });
    input.value = '';
    const typing = addModalTyping();
    try {
        const res = await fetch('/chat', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ system: SYSTEM, messages: modalHistory })
        });
        const data = await res.json();
        const block = data.content && data.content.find(function(b) { return b.type === 'text' && b.text; });
        const reply = block ? block.text : "Something went wrong. Try the full Meridian experience.";
        typing.remove();
        addModalMsg('bot', reply);
        modalHistory.push({ role: 'assistant', content: reply });
    } catch(e) {
        typing.remove();
        addModalMsg('bot', "Connection issue. Try the full Meridian experience instead.");
    }
}

document.getElementById('modal-msg').addEventListener('keydown', function(e) {
    if (e.key === 'Enter') modalSend();
});

document.querySelectorAll('a[href^="#"]').forEach(function(a) {
    a.addEventListener('click', function(e) {
        const target = document.querySelector(a.getAttribute('href'));
        if (target) { e.preventDefault(); target.scrollIntoView({ behavior: 'smooth' }); }
    });
});
</script>
