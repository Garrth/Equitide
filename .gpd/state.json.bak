        ]
      }
    ],
    "uncertainty_markers": {
      "weakest_anchors": [
        "Hydrofoil L/D ratio in low-speed water flow \u00e2\u20ac\u201d no measured value yet, using literature estimates",
        "Co-rotation drag reduction magnitude \u00e2\u20ac\u201d theoretical but unverified for this geometry"
      ],
      "unvalidated_assumptions": [
        "3 m/s vessel velocity is achievable and maintained under hydrofoil drag load",
        "Co-rotation of water body in 24ft cylinder is achievable and stable",
        "Tack-flip mechanism can reverse hydrofoil angle without significant energy loss"
      ],
      "competing_explanations": [
        "If hydrofoil L/D in this regime is low (less than 5), system may not reach 1.5W/W target",
        "Co-rotation may require energy input to maintain, reducing net gain"
      ],
      "disconfirming_observations": [
        "If complete system balance including all losses shows output/input less than 1.0, concept is not viable"
      ]
    }
  },
